---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Live Piano Performances — Dan Tremblay Music"
  description="Hire Dan Tremblay for live cinematic piano performances at weddings, corporate events, and private parties in Ottawa and Stittsville."
  solidNav={true}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Services · Live Performance</div>
      <h1 class="hero-title">Live Piano Performances in Stittsville &amp; Ottawa</h1>
      <p class="hero-sub">
        An intimate, cinematic live looping performance featuring all-original, chill vibes perfect
        for your event.
      </p>
      <a href="/contact" class="btn-filled">Book Your Event Now</a>
    </div>
  </section>

  <!-- PROMO VIDEO -->
  <section class="video-section">
    <div class="container">
      <div class="video-header">
        <span class="eyebrow">Watch the Promo Reel</span>
        <h2 class="section-h" style="text-align:center;margin-top:10px">
          Live Cinematic Looping
        </h2>
      </div>
      <div class="video-wrap">
        <iframe
          src="https://www.youtube.com/embed/ngVI3nZcTIc"
          title="Live Cinematic Looping Promo Reel — Dan Tremblay Music"
          allowfullscreen
          loading="lazy"></iframe>
      </div>
      <p class="video-caption">Live Cinematic Looping Promo Reel — Dan Tremblay Music</p>
    </div>
  </section>

  <!-- EVENT TYPES -->
  <section class="events">
    <div class="container">
      <div class="events-header">
        <span class="eyebrow">Perfect For</span>
        <h2 class="section-h" style="text-align:center;margin-top:10px">Types of Events</h2>
      </div>
      <div class="events-grid">
        <div class="event-card">
          <div class="event-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="9" cy="15" r="5" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="10" r="5" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <div class="event-title">Weddings &amp; Celebrations</div>
          <p class="event-desc">
            Set a sophisticated, memorable atmosphere for your ceremony, cocktail hour, or reception
            with cinematic live piano.
          </p>
        </div>
        <div class="event-card">
          <div class="event-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="5" y="3" width="10" height="18" stroke="currentColor" stroke-width="1.5"/><path d="M15 21V9l5 3v9" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M8 7h1M8 11h1M8 15h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="event-title">Corporate Events</div>
          <p class="event-desc">
            Elevate galas, product launches, and networking events with a unique ambient performance
            that sparks conversation.
          </p>
        </div>
        <div class="event-card">
          <div class="event-icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 21l3.5-9.5L14 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17 3l1.2 2.8L21 7l-2.8 1.2L17 11l-1.2-2.8L13 7l2.8-1.2L17 3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><circle cx="6.5" cy="17.5" r="1" fill="currentColor"/></svg>
          </div>
          <div class="event-title">Private Parties</div>
          <p class="event-desc">
            From intimate dinner parties to milestone birthdays, Dan's live looping style creates an
            unforgettable backdrop.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT TO EXPECT -->
  <section class="expect">
    <div class="container">
      <div class="expect-grid">
        <img
          src="/images/dan-live-small.webp"
          alt="Dan Tremblay performing live"
          class="expect-photo"
        />
        <div class="expect-content">
          <span class="eyebrow" style="color:rgba(255,255,255,0.4)">The Performance</span>
          <h2 class="section-h light">What to Expect</h2>
          <div class="check-list">
            <div class="check-item">All-original cinematic compositions</div>
            <div class="check-item">Live looping — built in real-time before your audience</div>
            <div class="check-item">Ambient, chill vibes that work in any setting</div>
            <div class="check-item">Professional, self-contained setup</div>
            <div class="check-item">Flexible set lengths to fit your event</div>
          </div>
          <div style="margin-top:16px">
            <a href="/contact" class="btn-filled">Contact for Availability</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container">
      <h2 class="cta-h">Hire Dan for Live Cinematic Piano Music</h2>
      <a href="/contact" class="btn-outline-white">Contact for Availability</a>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  /* HERO */
  .hero {
    padding-top: 64px;
    position: relative;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/dan-live.webp');
    background-size: cover;
    background-position: center 30%;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(5, 11, 27, 0.82) 0%, rgba(5, 11, 27, 0.65) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 80px clamp(20px, 5vw, 64px);
    max-width: 760px;
    text-align: center;
  }
  .hero-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.65);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }
  .hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(38px, 6vw, 72px);
    font-weight: 300;
    color: white;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin-bottom: 16px;
  }
  .hero-sub {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .btn-filled {
    display: inline-block;
    padding: 14px 32px;
    background: #4b5e92;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition:
      background 0.18s,
      transform 0.14s;
  }
  .btn-filled:hover {
    background: #3d4e7a;
    transform: translateY(-1px);
  }

  /* TYPOGRAPHY */
  .eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: #4b5e92;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }
  .section-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    line-height: 1.12;
    color: #0d1120;
    margin-bottom: 20px;
  }
  .section-h.light {
    color: white;
  }

  /* VIDEO */
  .video-section {
    padding: 96px 0;
    background: #eff5fc;
  }
  .video-section .container {
    max-width: 860px;
  }
  .video-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .video-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #050b1b;
  }
  .video-wrap iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-caption {
    text-align: center;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 14px;
    color: #5c6580;
    margin-top: 14px;
    font-style: italic;
  }

  /* EVENT TYPES */
  .events {
    padding: 96px 0;
    background: white;
  }
  .events-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .event-card {
    background: #eff5fc;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
    border-top: 2px solid transparent;
  }
  .event-card:hover {
    box-shadow: 0 8px 32px rgba(5, 11, 27, 0.09);
    transform: translateY(-3px);
    border-top-color: #4b5e92;
  }
  .event-icon {
    color: #4b5e92;
    margin-bottom: 4px;
  }
  .event-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #0d1120;
  }
  .event-desc {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: #5c6580;
    line-height: 1.7;
    text-wrap: pretty;
  }

  /* WHAT TO EXPECT */
  .expect {
    padding: 96px 0;
    background: #050b1b;
  }
  .expect-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .expect-photo {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .expect-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .check-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 4px;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.82);
  }
  .check-item::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: #4b5e92;
    flex-shrink: 0;
  }

  /* CTA */
  .cta-band {
    padding: 80px 0;
    background: #4b5e92;
    text-align: center;
  }
  .cta-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 400;
    color: white;
    margin-bottom: 28px;
  }
  .btn-outline-white {
    display: inline-block;
    padding: 14px 40px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      background 0.18s,
      border-color 0.18s;
  }
  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  @media (max-width: 960px) {
    .events-grid {
      grid-template-columns: 1fr 1fr;
    }
    .expect-grid {
      grid-template-columns: 1fr;
    }
    .expect-photo {
      max-height: 300px;
      object-position: center 30%;
    }
  }
  @media (max-width: 640px) {
    .events-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

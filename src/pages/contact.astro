---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Dan Tremblay Music"
  description="Get in touch with Dan Tremblay for piano lessons, music production services, or live event bookings in Ottawa."
  solidNav={true}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-content">
      <div class="page-eyebrow">Get in Touch</div>
      <h1 class="page-title">Contact</h1>
    </div>
  </section>

  <!-- CONTACT FORM + SIDEBAR -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- FORM -->
        <div>
          <h2 class="form-title">Get In Touch</h2>
          <p class="form-note">Fields marked with <span>*</span> are required.</p>
          <div id="form-success" class="form-success" style="display:none">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <p>Thank you! Your message has been sent. Dan will be in touch soon.</p>
          </div>
          <div id="form-error" class="form-error" style="display:none">
            <p>Something went wrong. Please try again or email directly.</p>
          </div>
          <form id="contact-form" method="POST" action="/api/contact">
            <div class="honeypot" aria-hidden="true">
              <label for="website">Leave this blank</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <div class="form-row">
              <div class="field">
                <label for="name">Name <span>*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>
              <div class="field">
                <label for="email">Email <span>*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
            </div>
            <div class="field">
              <label>What services are you interested in? <span>*</span></label>
              <div class="checkbox-group">
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="lessons" /> Piano Lessons
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="production" /> Music Production
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="booking" /> Booking Dan Live
                </label>
              </div>
            </div>
            <div class="field">
              <label for="message">Message <span>*</span></label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="Tell me a bit about what you're looking for…"></textarea>
            </div>
            <button type="submit" class="submit-btn" id="submit-btn">Send Message</button>
          </form>

          <script>
            const form = document.getElementById('contact-form') as HTMLFormElement;
            const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
            const successEl = document.getElementById('form-success') as HTMLElement;
            const errorEl = document.getElementById('form-error') as HTMLElement;

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              errorEl.style.display = 'none';
              submitBtn.disabled = true;
              submitBtn.textContent = 'Sending…';

              try {
                const res = await fetch('/api/contact', {
                  method: 'POST',
                  body: new FormData(form),
                });
                let payload: { success?: boolean; error?: string } = {};
                try { payload = await res.json(); } catch { /* non-JSON response */ }

                if (res.ok && payload.success) {
                  form.style.display = 'none';
                  successEl.style.display = 'flex';
                } else {
                  errorEl.querySelector('p')!.textContent = payload.error || 'Something went wrong. Please try again.';
                  errorEl.style.display = 'block';
                  submitBtn.disabled = false;
                  submitBtn.textContent = 'Send Message';
                }
              } catch {
                errorEl.querySelector('p')!.textContent = 'Something went wrong. Please try again.';
                errorEl.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Message';
              }
            });
          </script>
        </div>

        <!-- SIDEBAR -->
        <div class="contact-sidebar">
          <div class="sidebar-block">
            <div class="sidebar-block-title">Contact Info</div>
            <div class="info-item">
              <span class="info-label">Location</span>
              <span class="info-value">Stittsville, ON K2S 2G4<br />Canada</span>
            </div>
            <div class="info-item">
              <span class="info-label">Connect</span>
            </div>
            <div class="social-row">
              <a href="https://www.youtube.com/channel/UCRKCH91U2AhotO9nTlQP5OQ" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="https://dantremblay.bandcamp.com/releases" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Bandcamp">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
              </a>
              <a href="https://music.apple.com/ca/artist/dan-tremblay/300050749" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Apple Music">
                <svg width="20" height="20" viewBox="0 0 512 512" fill="currentColor"><path d="M199 359V199q0-9 10-11l138-28q11-2 12 10v122q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69V88s0-20-17-15l-170 35s-13 2-13 18v203q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69"/></svg>
              </a>
              <a href="https://www.instagram.com/dantremblaymusic/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162S8.597 18.163 12 18.163s6.162-2.759 6.162-6.162S15.403 5.838 12 5.838zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://www.twitch.tv/dantremblaymusic" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitch">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
              </a>
            </div>
          </div>
          <div class="sidebar-block">
            <div class="sidebar-block-title">Hours</div>
            <div class="hours-list">
              <div class="hour-row"><span class="hour-day">Monday</span><span>9 AM – 9 PM</span></div>
              <div class="hour-row"><span class="hour-day">Tuesday</span><span>9 AM – 9 PM</span></div>
              <div class="hour-row">
                <span class="hour-day">Wednesday</span><span>9 AM – 9 PM</span>
              </div>
              <div class="hour-row">
                <span class="hour-day">Thursday</span><span>9 AM – 9 PM</span>
              </div>
              <div class="hour-row"><span class="hour-day">Friday</span><span>9 AM – 6 PM</span></div>
              <div class="hour-row">
                <span class="hour-day">Saturday</span><span>10 AM – 2 PM</span>
              </div>
              <div class="hour-row"><span class="hour-day">Sunday</span><span>Closed</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    padding-top: 64px;
    position: relative;
    overflow: hidden;
    min-height: 280px;
    display: flex;
    align-items: center;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/piano.jpg');
    background-size: cover;
    background-position: center 40%;
  }
  .page-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(5, 11, 27, 0.82) 0%, rgba(5, 11, 27, 0.68) 100%);
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    padding: 56px clamp(20px, 5vw, 64px);
    text-align: center;
    width: 100%;
  }
  .page-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.65);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .page-eyebrow::before,
  .page-eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }
  .page-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 300;
    color: white;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Honeypot — hidden from real users, traps bots */
  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* CONTACT SECTION */
  .contact-section {
    padding: 96px 0;
    background: #eff5fc;
  }
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 72px;
    align-items: start;
  }

  /* FORM */
  .form-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    color: #0d1120;
    margin-bottom: 6px;
  }
  .form-note {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: #5c6580;
    margin-bottom: 32px;
  }
  .form-note span {
    color: #c0392b;
    font-weight: 600;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .field {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #0d1120;
    letter-spacing: 0.02em;
  }
  .field label span {
    color: #c0392b;
  }
  .field input,
  .field textarea {
    padding: 11px 14px;
    background: white;
    border: 1px solid rgba(13, 17, 32, 0.1);
    color: #0d1120;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    outline: none;
    transition: border-color 0.18s;
    width: 100%;
  }
  .field input:focus,
  .field textarea:focus {
    border-color: #4b5e92;
  }
  .field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
  }
  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: #5c6580;
    cursor: pointer;
  }
  .checkbox-item input {
    width: 16px;
    height: 16px;
    accent-color: #4b5e92;
    flex-shrink: 0;
  }
  .submit-btn {
    padding: 14px 36px;
    background: #4b5e92;
    color: white;
    border: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition:
      background 0.18s,
      transform 0.14s;
    margin-top: 6px;
  }
  .submit-btn:hover {
    background: #3d4e7a;
    transform: translateY(-1px);
  }
  .submit-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }
  .form-success {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 24px;
    background: #eaf4ee;
    border: 1px solid #a3d4b0;
    color: #1e5c32;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .form-success svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: #2d8c4e;
  }
  .form-success p {
    margin: 0;
  }
  .form-error {
    padding: 14px 18px;
    background: #fdf0ef;
    border: 1px solid #e8a9a3;
    color: #8c1f1a;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    margin-bottom: 18px;
  }
  .form-error p {
    margin: 0;
  }

  /* SIDEBAR */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .sidebar-block {
    padding: 28px;
    background: white;
    border: 1px solid rgba(13, 17, 32, 0.1);
  }
  .sidebar-block-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #0d1120;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(13, 17, 32, 0.1);
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 14px;
  }
  .info-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4b5e92;
  }
  .info-value {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: #5c6580;
    line-height: 1.6;
  }
  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hour-row {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: #5c6580;
    padding: 5px 0;
    border-bottom: 1px solid rgba(13, 17, 32, 0.1);
  }
  .hour-row:last-child {
    border-bottom: none;
  }
  .hour-day {
    font-weight: 500;
    color: #0d1120;
  }
  .social-row {
    display: flex;
    gap: 2px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #5c6580;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    transition: color 0.18s;
  }
  .social-link:hover {
    color: #4B5E92;
  }

  @media (max-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

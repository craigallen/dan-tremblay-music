---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Dan Tremblay Music"
  description="Get in touch with Dan Tremblay for piano lessons, music production services, or live event bookings in Ottawa."
  solidNav={true}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-content">
      <div class="page-eyebrow">Get in Touch</div>
      <h1 class="page-title">Contact</h1>
    </div>
  </section>

  <!-- CONTACT FORM + SIDEBAR -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- FORM -->
        <div>
          <h2 class="form-title">Get In Touch</h2>
          <p class="form-note">Fields marked with <span>*</span> are required.</p>
          <form>
            <div class="form-row">
              <div class="field">
                <label for="name">Name <span>*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>
              <div class="field">
                <label for="email">Email <span>*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
            </div>
            <div class="field">
              <label>What services are you interested in? <span>*</span></label>
              <div class="checkbox-group">
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="lessons" /> Piano Lessons
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="production" /> Music Production
                </label>
                <label class="checkbox-item">
                  <input type="checkbox" name="service" value="booking" /> Booking Dan Live
                </label>
              </div>
            </div>
            <div class="field">
              <label for="message">Message <span>*</span></label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="Tell me a bit about what you're looking for…"></textarea>
            </div>
            <button type="submit" class="submit-btn">Send Message</button>
          </form>
        </div>

        <!-- SIDEBAR -->
        <div class="contact-sidebar">
          <div class="sidebar-block">
            <div class="sidebar-block-title">Contact Info</div>
            <div class="info-item">
              <span class="info-label">Location</span>
              <span class="info-value">Stittsville, ON K2S 2G4<br />Canada</span>
            </div>
            <div class="info-item">
              <span class="info-label">Connect</span>
            </div>
            <div class="social-row">
              <a href="https://www.youtube.com/channel/UCRKCH91U2AhotO9nTlQP5OQ" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="https://dantremblay.bandcamp.com/releases" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Bandcamp">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
              </a>
              <a href="https://music.apple.com/ca/artist/dan-tremblay/300050749" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Apple Music">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.994 6.124a9.23 9.23 0 0 0-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a6.303 6.303 0 0 0-1.903-.833 9.874 9.874 0 0 0-1.87-.238c-.17-.008-.34-.012-.507-.012H6.75C4.048 0 1.875 2.012 1.875 4.5v15c0 2.488 2.173 4.5 4.875 4.5h10.5c2.702 0 4.875-2.012 4.875-4.5V6.5c0-.126-.002-.252-.006-.376zM12 3.557c2.008 0 3.638 1.63 3.638 3.638S14.008 10.833 12 10.833s-3.638-1.63-3.638-3.638S9.992 3.557 12 3.557zm0 13.526c-3.395 0-6.15-2.754-6.15-6.15h2.04c0 2.268 1.842 4.11 4.11 4.11s4.11-1.842 4.11-4.11h2.04c0 3.396-2.755 6.15-6.15 6.15z"/></svg>
              </a>
              <a href="https://open.spotify.com/artist/16bKDJq0aG9k0W3N0y1qqe" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Spotify">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
              </a>
              <a href="https://www.instagram.com/dantremblaymusic/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162S8.597 18.163 12 18.163s6.162-2.759 6.162-6.162S15.403 5.838 12 5.838zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://www.twitch.tv/dantremblaymusic" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitch">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
              </a>
            </div>
          </div>
          <div class="sidebar-block">
            <div class="sidebar-block-title">Hours</div>
            <div class="hours-list">
              <div class="hour-row"><span class="hour-day">Monday</span><span>9 AM – 9 PM</span></div>
              <div class="hour-row"><span class="hour-day">Tuesday</span><span>9 AM – 9 PM</span></div>
              <div class="hour-row">
                <span class="hour-day">Wednesday</span><span>9 AM – 9 PM</span>
              </div>
              <div class="hour-row">
                <span class="hour-day">Thursday</span><span>9 AM – 9 PM</span>
              </div>
              <div class="hour-row"><span class="hour-day">Friday</span><span>9 AM – 6 PM</span></div>
              <div class="hour-row">
                <span class="hour-day">Saturday</span><span>10 AM – 2 PM</span>
              </div>
              <div class="hour-row"><span class="hour-day">Sunday</span><span>Closed</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    padding-top: 64px;
    position: relative;
    overflow: hidden;
    min-height: 280px;
    display: flex;
    align-items: center;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/piano.jpg');
    background-size: cover;
    background-position: center 40%;
  }
  .page-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(5, 11, 27, 0.82) 0%, rgba(5, 11, 27, 0.68) 100%);
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    padding: 56px clamp(20px, 5vw, 64px);
    text-align: center;
    width: 100%;
  }
  .page-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.42);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .page-eyebrow::before,
  .page-eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }
  .page-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 300;
    color: white;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* CONTACT SECTION */
  .contact-section {
    padding: 96px 0;
    background: #eff5fc;
  }
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 72px;
    align-items: start;
  }

  /* FORM */
  .form-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    color: #0d1120;
    margin-bottom: 6px;
  }
  .form-note {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    color: #5c6580;
    margin-bottom: 32px;
  }
  .form-note span {
    color: #c0392b;
    font-weight: 600;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .field {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #0d1120;
    letter-spacing: 0.02em;
  }
  .field label span {
    color: #c0392b;
  }
  .field input,
  .field textarea {
    padding: 11px 14px;
    background: white;
    border: 1px solid rgba(13, 17, 32, 0.1);
    color: #0d1120;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.18s;
    width: 100%;
  }
  .field input:focus,
  .field textarea:focus {
    border-color: #4b5e92;
  }
  .field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
  }
  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }
  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    color: #5c6580;
    cursor: pointer;
  }
  .checkbox-item input {
    width: 16px;
    height: 16px;
    accent-color: #4b5e92;
    flex-shrink: 0;
  }
  .submit-btn {
    padding: 14px 36px;
    background: #4b5e92;
    color: white;
    border: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition:
      background 0.18s,
      transform 0.14s;
    margin-top: 6px;
  }
  .submit-btn:hover {
    background: #3d4e7a;
    transform: translateY(-1px);
  }

  /* SIDEBAR */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .sidebar-block {
    padding: 28px;
    background: white;
    border: 1px solid rgba(13, 17, 32, 0.1);
  }
  .sidebar-block-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: #0d1120;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(13, 17, 32, 0.1);
  }
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 14px;
  }
  .info-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4b5e92;
  }
  .info-value {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    color: #5c6580;
    line-height: 1.6;
  }
  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hour-row {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    color: #5c6580;
    padding: 5px 0;
    border-bottom: 1px solid rgba(13, 17, 32, 0.1);
  }
  .hour-row:last-child {
    border-bottom: none;
  }
  .hour-day {
    font-weight: 500;
    color: #0d1120;
  }
  .social-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .social-link {
    width: 34px;
    height: 34px;
    border: 1px solid rgba(13, 17, 32, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #5c6580;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    transition:
      border-color 0.18s,
      color 0.18s,
      background 0.18s;
  }
  .social-link:hover {
    border-color: #4b5e92;
    color: #4b5e92;
    background: rgba(75, 94, 146, 0.06);
  }

  @media (max-width: 960px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

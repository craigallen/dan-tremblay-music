---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Music Production Services — Dan Tremblay Music"
  description="Professional music production services from Dan Tremblay — custom compositions, recording, mixing, and mastering for artists, film, and interactive media."
  solidNav={true}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Services · Music Production</div>
      <h1 class="hero-title">Music Production Services</h1>
      <p class="hero-sub">
        30+ years of experience creating custom compositions, recording, mixing, and mastering.
      </p>
      <a href="/contact" class="btn-filled">Start Your Music Project Today</a>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="why">
    <div class="container">
      <div class="why-grid">
        <img
          src="/images/dan-production.webp"
          alt="Dan Tremblay in his studio"
          class="why-photo"
        />
        <div>
          <span class="eyebrow">Why Work With Dan</span>
          <h2 class="section-h">Why Choose Dan Tremblay for Music Production</h2>
          <div class="check-list">
            <div class="check-item">30+ Years of Experience in Music Production</div>
            <div class="check-item">Custom Compositions for Any Project</div>
            <div class="check-item">Recording, Mixing, and Mastering Services</div>
            <div class="check-item">Trusted by creators worldwide</div>
            <div class="check-item">Cinematic &amp; electronic music specialist</div>
          </div>
          <a href="/contact" class="btn-navy">Request a Free Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section class="portfolio">
    <div class="container">
      <div class="portfolio-header">
        <span class="eyebrow">Listen</span>
        <h2 class="section-h" style="text-align:center;margin-top:10px">Production Work</h2>
      </div>
      <div class="spotify-embed-wrap">
        <iframe
          src="https://open.spotify.com/embed/playlist/6AOsg7dyA8fPlLFxPN1exh"
          width="100%"
          height="380"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="Dan Tremblay — Production Playlist"></iframe>
      </div>
    </div>
  </section>

  <!-- PROJECT TYPES -->
  <section class="project-types">
    <div class="container">
      <div class="project-types-header">
        <span class="eyebrow">Specializations</span>
        <h2 class="section-h" style="text-align:center;margin-top:10px">
          Types of Projects I Work On
        </h2>
      </div>
      <div class="projects-grid">
        <div class="project-card">
          <div class="project-card-img">
            <img src="/images/dan-live.webp" alt="Music for Artists and Bands" />
          </div>
          <div class="project-card-body">
            <div class="project-card-title">Music for Artists &amp; Bands</div>
            <p class="project-card-desc">
              Full production support for singer-songwriters, bands, and independent artists — from
              demos to release-ready masters.
            </p>
          </div>
        </div>
        <div class="project-card">
          <div class="project-card-img">
            <img src="/images/dan-teaching-piano.webp" alt="Media and Commercial Productions" />
          </div>
          <div class="project-card-body">
            <div class="project-card-title">Media &amp; Commercial Productions</div>
            <p class="project-card-desc">
              Original compositions and music supervision for film, television, advertising, and
              digital media projects.
            </p>
          </div>
        </div>
        <div class="project-card">
          <div class="project-card-img">
            <img
              src="/images/dan-production.webp"
              alt="Game Soundtracks and Interactive Media"
            />
          </div>
          <div class="project-card-body">
            <div class="project-card-title">Game Soundtracks &amp; Interactive Media</div>
            <p class="project-card-desc">
              Adaptive, cinematic scores for video games, VR experiences, and interactive
              installations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container">
      <h2 class="cta-h">Contact Dan for Professional Music Production</h2>
      <a href="/contact" class="btn-outline-white">Request a Consultation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  /* HERO */
  .hero {
    padding-top: 64px;
    position: relative;
    overflow: hidden;
    min-height: 460px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/dan-production.webp');
    background-size: cover;
    background-position: center;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(5, 11, 27, 0.85) 0%, rgba(5, 11, 27, 0.68) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 80px clamp(20px, 5vw, 64px);
    max-width: 760px;
    text-align: center;
  }
  .hero-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: rgba(255, 255, 255, 0.42);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }
  .hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(36px, 5.5vw, 68px);
    font-weight: 300;
    color: white;
    letter-spacing: 0.03em;
    line-height: 1.08;
    margin-bottom: 16px;
  }
  .hero-sub {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .btn-filled {
    display: inline-block;
    padding: 14px 32px;
    background: #4b5e92;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition:
      background 0.18s,
      transform 0.14s;
  }
  .btn-filled:hover {
    background: #3d4e7a;
    transform: translateY(-1px);
  }

  /* TYPOGRAPHY */
  .eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: #4b5e92;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }
  .section-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    line-height: 1.12;
    color: #0d1120;
    margin-bottom: 20px;
  }
  .btn-navy {
    display: inline-block;
    padding: 13px 28px;
    background: #050b1b;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    letter-spacing: 0.04em;
    transition:
      background 0.18s,
      transform 0.14s;
  }
  .btn-navy:hover {
    background: #4b5e92;
    transform: translateY(-1px);
  }

  /* WHY */
  .why {
    padding: 96px 0;
    background: #eff5fc;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .why-photo {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }
  .check-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 20px 0 28px;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    color: #5c6580;
  }
  .check-item::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: #4b5e92;
    flex-shrink: 0;
  }

  /* PORTFOLIO */
  .portfolio {
    padding: 96px 0;
    background: white;
  }
  .portfolio-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .spotify-embed-wrap {
    max-width: 780px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
  }

  /* PROJECT TYPES */
  .project-types {
    padding: 96px 0;
    background: #eff5fc;
  }
  .project-types-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .project-card {
    overflow: hidden;
    background: white;
    border: 1px solid rgba(13, 17, 32, 0.1);
    transition:
      box-shadow 0.22s,
      transform 0.22s;
  }
  .project-card:hover {
    box-shadow: 0 8px 32px rgba(5, 11, 27, 0.1);
    transform: translateY(-3px);
  }
  .project-card-img {
    aspect-ratio: 3/2;
    overflow: hidden;
    position: relative;
  }
  .project-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .project-card:hover .project-card-img img {
    transform: scale(1.04);
  }
  .project-card-body {
    padding: 22px 24px;
  }
  .project-card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 20px;
    font-weight: 600;
    color: #0d1120;
    margin-bottom: 8px;
  }
  .project-card-desc {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    color: #5c6580;
    line-height: 1.65;
    text-wrap: pretty;
  }

  /* CTA */
  .cta-band {
    padding: 80px 0;
    background: #4b5e92;
    text-align: center;
  }
  .cta-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 400;
    color: white;
    margin-bottom: 28px;
  }
  .btn-outline-white {
    display: inline-block;
    padding: 14px 40px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      background 0.18s,
      border-color 0.18s;
  }
  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  @media (max-width: 960px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
.projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

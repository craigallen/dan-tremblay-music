---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Dan Tremblay Music — Piano Lessons in Stittsville, Ottawa">

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <canvas id="hero-particles"></canvas>
    <div class="hero-content">
      <div class="hero-eyebrow">Piano · Lessons · Ottawa</div>
      <h1 class="hero-name">Dan Tremblay</h1>
      <div class="hero-rule"></div>
      <p class="hero-title">Piano Lessons in Stittsville, Ottawa</p>
      <p class="hero-sub">
        Award-winning instruction for children, teens, and adults.<br />
        Build skills, confidence, and creativity.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn-filled">Book Your Free Lesson</a>
        <a href="/about" class="btn-ghost">Learn More About Dan</a>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ─────────────────────────────────────────────── -->
  <section class="about" id="lessons">
    <div class="container">
      <div class="about-grid">
        <div class="about-photo-wrap">
          <img
            src="/images/dan-tremblay.jpeg"
            alt="Dan Tremblay"
            class="about-photo"
          />
          <div class="about-photo-accent"></div>
        </div>
        <div class="about-content">
          <span class="eyebrow">Based in Stittsville, Ottawa</span>
          <h2 class="section-h">About Dan</h2>
          <p class="about-body">
            Dan Tremblay is a piano instructor and producer with over three decades
            of experience. His dedication to teaching has led his students to success
            at the provincial level, while his own compositions have been licensed
            worldwide for multi-media productions.
          </p>
          <p class="about-body">
            Dan's popular YouTube channel has connected him with leading music
            technology companies and internationally recognized composers such as
            Christopher Norton. Alongside teaching, he continues to
            <a href="/production">produce music for artists</a> and game soundtracks,
            keeping his work current and inspiring.
          </p>
          <div class="badges">
            <span class="badge">8× Provincial Awards</span>
            <span class="badge">30+ Years Teaching</span>
            <span class="badge">Published Composer</span>
            <span class="badge">YouTube Creator</span>
          </div>
          <a href="/about" class="btn-navy">Learn More About Dan</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── OFFERINGS ─────────────────────────────────────────── -->
  <section class="offerings">
    <div class="offerings-bg"></div>
    <div class="container">
      <div class="offerings-grid">
        <div class="offerings-content">
          <div class="offerings-group">
            <h3 class="offerings-group-title">What I Offer</h3>
            <div class="check-list">
              <div class="check-item">Exam Preparation</div>
              <div class="check-item">Improvisation Instruction</div>
              <div class="check-item">Popular Music</div>
              <div class="check-item">Music Production</div>
            </div>
          </div>
          <div class="offerings-group">
            <h3 class="offerings-group-title">Why Choose Me</h3>
            <div class="check-list">
              <div class="check-item">Home of 8 provincial awards</div>
              <div class="check-item">Thirty years of experience</div>
              <div class="check-item">Published multimedia composer</div>
            </div>
          </div>
        </div>
        <div class="offerings-photo-wrap">
          <img
            src="/images/dan-teaching-piano.webp"
            alt="Dan teaching piano"
            class="offerings-photo"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── SERVICES ───────────────────────────────────────────── -->
  <section class="services" id="services">
    <div class="container">
      <div class="services-header">
        <span class="eyebrow">Beyond Lessons</span>
        <h2 class="section-h" style="margin-top:10px">Other Music Services</h2>
      </div>
      <div class="services-grid">
        <a href="/production" class="service-card">
          <div class="service-card-img">
            <img src="/images/dan-production.webp" alt="Music Production Services" />
          </div>
          <div class="service-card-body">
            <div class="service-card-title">Production Services</div>
            <p class="service-card-desc">
              Professional music production in Ottawa — from mixing and mastering to
              custom compositions for songs, videos, and media projects.
            </p>
            <span class="service-card-link">Learn More</span>
          </div>
        </a>
        <a
          href="https://dan-s-site-8ede.thinkific.com/collections"
          target="_blank"
          rel="noopener noreferrer"
          class="service-card"
        >
          <div class="service-card-img">
            <img src="/images/online-course-small.webp" alt="Online Piano Courses" />
          </div>
          <div class="service-card-body">
            <div class="service-card-title">Online Courses</div>
            <p class="service-card-desc">
              Learn piano online at your own pace with step-by-step courses. Expert
              techniques for beginners to advanced students.
            </p>
            <span class="service-card-link">Browse Courses</span>
          </div>
        </a>
        <a href="/live" class="service-card">
          <div class="service-card-img">
            <img src="/images/dan-live-small.webp" alt="Book Dan Live" />
          </div>
          <div class="service-card-body">
            <div class="service-card-title">Book Dan Live</div>
            <p class="service-card-desc">
              An intimate, cinematic live looping performance featuring all-original,
              chill vibes perfect for weddings, corporate events, and private parties.
            </p>
            <span class="service-card-link">Learn More</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ───────────────────────────────────────── -->
  <section class="testimonials">
    <div class="container">
      <div class="testimonials-header">
        <span class="eyebrow">What Students Say</span>
        <h2 class="section-h" style="margin-top:10px">Testimonials</h2>
      </div>
      <div class="featured-quote">
        <span class="quote-opener">"</span>
        <p class="quote-text">
          Dan Tremblay has taught our daughter since she was a young child, instilling
          a love for music and playing the piano. This has given our daughter the
          fundamentals and confidence to complete her level 6 Conservatory Canada Piano
          and Theory Exam. I highly recommend Dan Tremblay Music if you are considering
          music lessons for your child.
        </p>
        <p class="quote-attr">— William F.</p>
      </div>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-header">
            <div class="review-av">L</div>
            <div>
              <div class="review-name">Lauren F.</div>
              <div class="review-meta">6 months ago</div>
            </div>
          </div>
          <div class="review-stars">★★★★★</div>
          <p class="review-text">
            I had a great experience working on my first single with Dan! He was very
            friendly and helpful in helping me understand the process and was able to
            bring my vision to life.
          </p>
          <div class="google-badge">
            <span class="google-g">G</span> Google Review
          </div>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="review-av" style="background:#5a8c6b">K</div>
            <div>
              <div class="review-name">Katie S.</div>
              <div class="review-meta">6 months ago</div>
            </div>
          </div>
          <div class="review-stars">★★★★★</div>
          <p class="review-text">
            My daughter started with Dan as a beginner almost 2 years ago. He has been
            so patient and encouraging with her and she has improved so much. Highly
            recommend!
          </p>
          <div class="google-badge">
            <span class="google-g">G</span> Google Review
          </div>
        </div>
        <div class="review-card">
          <div class="review-header">
            <div class="review-av" style="background:#8c6b5a">J</div>
            <div>
              <div class="review-name">Jill D.</div>
              <div class="review-meta">6 months ago</div>
            </div>
          </div>
          <div class="review-stars">★★★★★</div>
          <p class="review-text">
            Mr. Dan Tremblay has been my daughter's piano teacher for 12 years. He
            knows his music and he is incredibly personable. He is the best teacher
            she has ever had.
          </p>
          <div class="google-badge">
            <span class="google-g">G</span> Google Review
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ───────────────────────────────────────────── -->
  <section class="cta-band">
    <div class="container">
      <h2 class="cta-band-h">Ready to Learn Piano in Stittsville?</h2>
      <a href="/contact" class="btn-outline-white">Book Your Lesson</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── CONTAINER ───────────────────────────────────────── */
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  /* ── SHARED TYPOGRAPHY ───────────────────────────────── */
  .eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: #4b5e92;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }

  .section-h {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(32px, 3vw, 46px);
    font-weight: 400;
    line-height: 1.12;
    color: #0d1120;
    margin-bottom: 20px;
  }

  /* ── SHARED BUTTONS ──────────────────────────────────── */
  .btn-filled {
    padding: 14px 32px;
    background: #4b5e92;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: background 0.18s, transform 0.14s;
    display: inline-block;
  }

  .btn-filled:hover {
    background: #3d4e7a;
    transform: translateY(-1px);
  }

  .btn-ghost {
    padding: 14px 32px;
    border: 1px solid rgba(255, 255, 255, 0.38);
    color: rgba(255, 255, 255, 0.85);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: border-color 0.18s, color 0.18s;
    display: inline-block;
  }

  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.72);
    color: white;
  }

  .btn-navy {
    display: inline-block;
    padding: 13px 28px;
    background: #050b1b;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: background 0.18s, transform 0.14s;
  }

  .btn-navy:hover {
    background: #4b5e92;
    transform: translateY(-1px);
  }

  .btn-outline-white {
    display: inline-block;
    padding: 14px 40px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.18s, border-color 0.18s;
  }

  .btn-outline-white:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  /* ── HERO ────────────────────────────────────────────── */
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/piano.jpg');
    background-size: cover;
    background-position: center 30%;
  }

  #hero-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(5, 11, 27, 0.72) 0%,
      rgba(5, 11, 27, 0.55) 50%,
      rgba(5, 11, 27, 0.68) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 100px clamp(20px, 5vw, 64px) 80px;
    max-width: 860px;
  }

  .hero-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.26em;
    color: rgba(255, 255, 255, 0.42);
    text-transform: uppercase;
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    opacity: 0;
    animation: heroFadeUp 0.9s ease forwards 0.3s;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    display: block;
    width: 36px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(58px, 9vw, 104px);
    font-weight: 300;
    color: white;
    letter-spacing: 0.14em;
    line-height: 0.92;
    text-transform: uppercase;
    margin-bottom: 22px;
    opacity: 0;
    animation: heroFadeUp 1s ease forwards 0.65s;
  }

  .hero-rule {
    width: 56px;
    height: 1px;
    background: rgba(255, 255, 255, 0.28);
    margin: 0 auto 22px;
    opacity: 0;
    animation: heroFadeUp 0.9s ease forwards 1s;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(20px, 2.6vw, 30px);
    font-weight: 400;
    font-style: italic;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 10px;
    opacity: 0;
    animation: heroFadeUp 0.9s ease forwards 1.15s;
  }

  .hero-sub {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 42px;
    line-height: 1.7;
    opacity: 0;
    animation: heroFadeUp 0.9s ease forwards 1.3s;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroFadeUp 0.9s ease forwards 1.5s;
  }

  /* ── ABOUT ───────────────────────────────────────────── */
  .about {
    padding: 96px 0;
    background: #eff5fc;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .about-photo-wrap {
    position: relative;
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: top;
    display: block;
    position: relative;
    z-index: 1;
  }

  .about-photo-accent {
    position: absolute;
    top: -14px;
    left: -14px;
    right: 14px;
    bottom: 14px;
    border: 1.5px solid #4b5e92;
    opacity: 0.28;
    pointer-events: none;
    z-index: 0;
  }

  .about-body {
    font-size: 15px;
    color: #5c6580;
    line-height: 1.8;
    text-wrap: pretty;
    margin-bottom: 14px;
  }

  .about-body a {
    color: #4b5e92;
    border-bottom: 1px solid transparent;
    transition: border-color 0.18s;
  }

  .about-body a:hover {
    border-color: #4b5e92;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 22px 0 28px;
  }

  .badge {
    padding: 6px 14px;
    border: 1px solid #4b5e92;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 12px;
    color: #4b5e92;
    letter-spacing: 0.03em;
    background: transparent;
  }

  /* ── OFFERINGS ───────────────────────────────────────── */
  .offerings {
    padding: 96px 0;
    position: relative;
    overflow: hidden;
  }

  .offerings-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/dan-live.webp');
    background-size: cover;
    background-position: center;
  }

  .offerings-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(5, 11, 27, 0.88);
  }

  .offerings-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .offerings-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .offerings-group-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 24px;
    font-weight: 400;
    color: white;
    letter-spacing: 0.02em;
    margin-bottom: 14px;
  }

  .check-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.72);
  }

  .check-item::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: #4b5e92;
    flex-shrink: 0;
  }

  .offerings-photo-wrap {
    position: relative;
  }

  .offerings-photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ── SERVICES ────────────────────────────────────────── */
  .services {
    padding: 96px 0;
    background: #eff5fc;
  }

  .services-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: white;
    transition: box-shadow 0.22s, transform 0.22s;
    position: relative;
    overflow: hidden;
  }

  .service-card:hover {
    box-shadow: 0 10px 40px rgba(5, 11, 27, 0.12);
    transform: translateY(-4px);
    z-index: 2;
  }

  .service-card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    position: relative;
  }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-card-img img {
    transform: scale(1.04);
  }

  .service-card-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .service-card-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 24px;
    font-weight: 600;
    color: #0d1120;
    line-height: 1.15;
  }

  .service-card-desc {
    font-size: 14px;
    color: #5c6580;
    line-height: 1.7;
    text-wrap: pretty;
    flex: 1;
  }

  .service-card-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #4b5e92;
    letter-spacing: 0.04em;
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: gap 0.18s;
  }

  .service-card:hover .service-card-link {
    gap: 9px;
  }

  .service-card-link::after {
    content: '→';
  }

  /* ── TESTIMONIALS ────────────────────────────────────── */
  .testimonials {
    padding: 96px 0;
    background: #eff5fc;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .featured-quote {
    max-width: 760px;
    margin: 0 auto 52px;
    padding: 44px 52px;
    background: white;
    border-top: 2px solid #4b5e92;
    box-shadow: 0 2px 24px rgba(5, 11, 27, 0.06);
  }

  .quote-opener {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 88px;
    color: #4b5e92;
    line-height: 0.55;
    display: block;
    margin-bottom: 16px;
    opacity: 0.35;
    user-select: none;
  }

  .quote-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 400;
    font-style: italic;
    color: #0d1120;
    line-height: 1.72;
    text-wrap: pretty;
  }

  .quote-attr {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #5c6580;
    margin-top: 24px;
    letter-spacing: 0.04em;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .review-card {
    background: white;
    padding: 24px;
    border: 1px solid rgba(13, 17, 32, 0.1);
    transition: box-shadow 0.2s;
  }

  .review-card:hover {
    box-shadow: 0 4px 20px rgba(5, 11, 27, 0.07);
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .review-av {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #4b5e92;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: white;
  }

  .review-name {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #0d1120;
  }

  .review-meta {
    font-size: 11px;
    color: #5c6580;
    margin-top: 1px;
  }

  .review-stars {
    color: #f4a11f;
    font-size: 13px;
    letter-spacing: 2px;
    margin-bottom: 10px;
  }

  .review-text {
    font-size: 13px;
    color: #5c6580;
    line-height: 1.68;
    text-wrap: pretty;
  }

  .google-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    font-size: 11px;
    color: #5c6580;
    font-weight: 500;
  }

  .google-g {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #4285f4;
    display: inline-flex;
    align-items: center;
    justify-content: center;

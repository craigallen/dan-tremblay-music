<script>
  const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width  = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    radius: number;
    alpha: number;
    alphaDir: number;
  }

  const COUNT = 70;
  const particles: Particle[] = [];

  for (let i = 0; i < COUNT; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.22,
      vy: -Math.random() * 0.18 - 0.06,
      radius: Math.random() * 1.8 + 0.4,
      alpha: Math.random() * 0.35 + 0.05,
      alphaDir: Math.random() < 0.5 ? 1 : -1,
    });
  }

  function tick() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const p of particles) {
      p.x  += p.vx;
      p.y  += p.vy;
      p.alpha += p.alphaDir * 0.0008;

      if (p.alpha > 0.4)  p.alphaDir = -1;
      if (p.alpha < 0.03) p.alphaDir =  1;

      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < -4) { p.y = canvas.height; p.x = Math.random() * canvas.width; }

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${p.alpha})`;
      ctx.fill();
    }

    requestAnimationFrame(tick);
  }
  tick();
</script>

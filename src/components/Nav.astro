---
interface Props {
  solidNav?: boolean;
}
const { solidNav = false } = Astro.props;
---

<nav class={`nav${solidNav ? ' is-scrolled' : ''}`} id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/images/dt-white.png" alt="Dan Tremblay Music" width="44" height="44" />
    </a>
    <div class="nav-links">
      <a href="/about" class="nav-link">About</a>
      <div class="nav-dropdown">
        <button class="nav-link nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
          Services <svg class="nav-chevron" aria-hidden="true" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 5L7 9.5L11.5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/production" class="nav-dropdown-item" role="menuitem">Music Production</a>
          <a href="/live" class="nav-dropdown-item" role="menuitem">Book Dan Live</a>
          <a href="https://dan-s-site-8ede.thinkific.com/collections" class="nav-dropdown-item" role="menuitem" target="_blank" rel="noopener noreferrer">Online Courses</a>
        </div>
      </div>
      <a href="https://dantremblay.bandcamp.com/" class="nav-link" target="_blank" rel="noopener noreferrer">Discography</a>
      <a href="/contact" class="nav-btn">Book a Lesson</a>
    </div>
    <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile" id="mobile-menu">
    <a href="/about" class="nav-link">About</a>
    <div class="nav-mobile-group">
      <span class="nav-link nav-mobile-label">Services</span>
      <div class="nav-mobile-sub">
        <a href="/production" class="nav-link nav-mobile-sub-link">Music Production</a>
        <a href="/live" class="nav-link nav-mobile-sub-link">Book Dan Live</a>
        <a href="https://dan-s-site-8ede.thinkific.com/collections" class="nav-link nav-mobile-sub-link" target="_blank" rel="noopener noreferrer">Online Courses</a>
      </div>
    </div>
    <a href="https://dantremblay.bandcamp.com/" class="nav-link" target="_blank" rel="noopener noreferrer">Discography</a>
    <a href="/contact" class="nav-btn">Book a Lesson</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    background: rgba(75, 94, 146, 0);
    backdrop-filter: blur(0px);
    transition: background 0.35s, backdrop-filter 0.35s, box-shadow 0.35s;
  }

  .nav.is-scrolled {
    background: rgba(75, 94, 146, 0.97);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .nav-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
    height: 64px;
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 44px;
    width: 44px;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-left: auto;
  }

  .nav-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    letter-spacing: 0.01em;
    transition: color 0.18s;
  }

  .nav-link:hover {
    color: #fff;
  }

  .nav-btn {
    padding: 9px 22px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: background 0.18s, border-color 0.18s;
  }

  .nav-btn:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .nav-hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    margin: 5px 0;
    transition: 0.2s;
  }

  .nav-mobile {
    display: none;
    background: rgba(75, 94, 146, 0.98);
    padding: 16px clamp(20px, 5vw, 64px) 20px;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-mobile .nav-link {
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 17px;
  }

  .nav-mobile .nav-btn {
    margin-top: 8px;
    text-align: center;
    display: block;
  }

  .nav-mobile.open {
    display: flex;
  }

  /* DROPDOWN */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-toggle {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 2px;
    border-radius: 4px;
  }

  .nav-dropdown-toggle:focus-visible,
  .nav-link:focus-visible,
  .nav-btn:focus-visible,
  .nav-hamburger:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.85);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .nav-chevron {
    width: 16px;
    height: 16px;
    transition: transform 0.22s ease;
    display: inline-block;
    margin-left: 3px;
    flex-shrink: 0;
    transform-origin: center center;
  }

  .nav-dropdown-toggle[aria-expanded='true'] .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 18px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 180px;
    background: rgba(75, 94, 146, 0.97);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(5, 11, 27, 0.25);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-4px);
    transition:
      opacity 0.18s,
      transform 0.18s;
  }

  .nav-dropdown-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-item {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.82);
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition: background 0.14s, color 0.14s;
    white-space: nowrap;
  }

  .nav-dropdown-item:last-child {
    border-bottom: none;
  }

  .nav-dropdown-item:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  /* MOBILE SUB-LINKS */
  .nav-mobile-group {
    display: flex;
    flex-direction: column;
  }

  .nav-mobile-label {
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    font-size: 17px;
  }

  .nav-mobile-sub {
    display: flex;
    flex-direction: column;
    padding-left: 16px;
    background: rgba(0, 0, 0, 0.1);
  }

  .nav-mobile-sub-link {
    font-size: 15px !important;
    padding: 9px 0 !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
    .nav-hamburger {
      display: block;
    }
  }
</style>

<script define:vars={{ solidNav }}>
  const nav = document.getElementById('nav');

  if (!solidNav) {
    nav.classList.toggle('is-scrolled', window.scrollY > 50);
    window.addEventListener(
      'scroll',
      () => {
        nav.classList.toggle('is-scrolled', window.scrollY > 50);
      },
      { passive: true }
    );
  }

  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  hamburger.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
  });

  const dropdownToggle = document.querySelector('.nav-dropdown-toggle');
  const dropdownMenu = document.querySelector('.nav-dropdown-menu');

  if (dropdownToggle && dropdownMenu) {
    dropdownToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdownMenu.classList.toggle('open');
      dropdownToggle.setAttribute('aria-expanded', String(isOpen));
    });

    document.addEventListener('click', () => {
      dropdownMenu.classList.remove('open');
      dropdownToggle.setAttribute('aria-expanded', 'false');
    });

    dropdownMenu.addEventListener('click', (e) => e.stopPropagation());
  }
</script>

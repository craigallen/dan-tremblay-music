    <div class="footer-bottom">
      <span class="footer-copy">© {year} Dan Tremblay Music. All rights reserved.</span>
      <span class="footer-copy"><a href="#">Sitemap</a></span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #050b1b;
    padding: 64px 0 28px;
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand-logo {
    height: 44px;
    width: 44px;
    object-fit: contain;
    margin-bottom: 16px;
  }

  .footer-brand-desc {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.8;
    max-width: 220px;
  }

  .footer-col-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 18px;
    display: block;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.01em;
    transition: color 0.18s;
  }

  .footer-link:hover {
    color: white;
  }

  .footer-input-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .footer-input {
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    outline: none;
    transition: border-color 0.18s;
  }

  .footer-input::placeholder {
    color: rgba(255, 255, 255, 0.28);
  }

  .footer-input:focus {
    border-color: #4b5e92;
  }

  .footer-sub-btn {
    padding: 10px 18px;
    background: #4b5e92;
    border: none;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.18s;
  }

  .footer-sub-btn:hover {
    background: #3d4e7a;
  }

  .social-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .social-link {
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    transition: border-color 0.18s, color 0.18s;
  }

  .social-link:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: white;
  }

  .footer-bottom {
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.22);
    letter-spacing: 0.02em;
  }

  .footer-copy a {
    color: rgba(255, 255, 255, 0.22);
    transition: color 0.18s;
  }

  .footer-copy a:hover {
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

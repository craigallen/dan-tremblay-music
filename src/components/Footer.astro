---
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <img
          src="/images/dt-white.png"
          alt="Dan Tremblay Music"
          class="footer-brand-logo"
        />
        <p class="footer-brand-desc">
          Award-winning piano instruction and music production in Stittsville, Ottawa.
        </p>
      </div>

      <div>
        <span class="footer-col-label">Navigate</span>
        <div class="footer-links">
          <a href="/" class="footer-link">Home</a>
          <a href="/about" class="footer-link">About</a>
          <a href="/contact" class="footer-link">Contact</a>
          <a
            href="https://dantremblay.bandcamp.com/"
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer">Discography</a
          >
        </div>
      </div>

      <div>
        <span class="footer-col-label">Services</span>
        <div class="footer-links">
          <a href="/production" class="footer-link">Production Services</a>
          <a
            href="https://dan-s-site-8ede.thinkific.com/collections"
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer">Online Courses</a
          >
          <a href="/live" class="footer-link">Book Dan Live</a>
        </div>
      </div>

      <div>
        <span class="footer-col-label">Subscribe for Updates</span>
        <div class="footer-input-row">
          <form action="https://dantremblaymusic.us7.list-manage.com/subscribe/post?u=aeadd9708351301c81eccd743&amp;id=204fda22b5&amp;f_id=00e2c2e1f0" method="post" id="mc-embedded-subscribe-form" name="mc-embedded-subscribe-form" class="validate" target="_blank" novalidate>
            <input type="email" name="EMAIL" class="footer-input" id="mce-EMAIL" placeholder="Email address" required />
            <div aria-hidden="true" style="position: absolute; left: -5000px;">
              <input type="text" name="b_aeadd9708351301c81eccd743_204fda22b5" tabindex="-1" value="" />
            </div>
            <button type="submit" name="subscribe" id="mc-embedded-subscribe" class="footer-sub-btn">Subscribe</button>
          </form>
        </div>
        <span class="footer-col-label">Connect</span>
        <div class="social-row">
          <a href="https://www.youtube.com/channel/UCRKCH91U2AhotO9nTlQP5OQ" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://dantremblay.bandcamp.com/releases" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Bandcamp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
          </a>
          <a href="https://music.apple.com/ca/artist/dan-tremblay/300050749" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Apple Music">
            <svg width="20" height="20" viewBox="0 0 512 512" fill="currentColor"><path d="M199 359V199q0-9 10-11l138-28q11-2 12 10v122q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69V88s0-20-17-15l-170 35s-13 2-13 18v203q0 15-45 20c-57 9-48 105 30 79 30-11 35-40 35-69"/></svg>
          </a>
          <a href="https://www.instagram.com/dantremblaymusic/" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162S8.597 18.163 12 18.163s6.162-2.759 6.162-6.162S15.403 5.838 12 5.838zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://www.twitch.tv/dantremblaymusic" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitch">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year} Dan Tremblay Music. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #050b1b;
    padding: 64px 0 28px;
  }

  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-brand-logo {
    height: 44px;
    width: 44px;
    object-fit: contain;
    margin-bottom: 16px;
  }

  .footer-brand-desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.8;
    max-width: 220px;
  }

  .footer-col-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 18px;
    display: block;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.72);
    letter-spacing: 0.01em;
    transition: color 0.18s;
  }

  .footer-link:hover {
    color: white;
  }

  .footer-input-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .footer-input-row form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .footer-input {
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    outline: none;
    transition: border-color 0.18s;
  }

  .footer-input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-input:focus {
    border-color: #4b5e92;
  }

  .footer-sub-btn {
    padding: 10px 18px;
    background: #4b5e92;
    border: none;
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.18s;
  }

  .footer-sub-btn:hover {
    background: #3d4e7a;
  }

  .social-row {
    display: flex;
    gap: 2px;
    flex-wrap: wrap;
  }

  .social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.65);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    transition: color 0.18s;
  }

  .social-link:hover {
    color: #EFF5FC;
  }

  .footer-bottom {
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.02em;
  }

  .footer-copy a {
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.18s;
  }

  .footer-copy a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
